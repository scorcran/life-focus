{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "dist",
    "rootDir": "src",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "plugins": [{"name": "next"}]
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts", "node_modules"],
  "references": [
    {"path": "../../packages/config"},
    {"path": "../../packages/db"}
  ]
}
