{
  "name": "life-focus",
  "private": true,
  "type": "module",
  "engines": { "node": ">=24" },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=apps/web\" \"npm run dev --workspace=apps/worker\"",
    "build": "npm run build --workspace=packages --if-present && npm run build --workspace=apps --if-present",
    "lint": "eslint . --ignore-pattern 'fixtures/**' && bash check-fixtures.sh",
    "typecheck": "tsc --build tsconfig.build.json && tsc -p tsconfig.tests.json --noEmit && tsc -p tsconfig.tests.web.json --noEmit",
    "test": "vitest run",
    "loop:ship": "bash scripts/bmad-loop-ship.sh"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/eslint-parser": "^8.0.1",
    "@babel/preset-react": "^8.0.1",
    "@babel/preset-typescript": "^8.0.1",
    "@eslint/js": "^9.0.0",
    "@types/node": "^24.0.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "shadcn": "^4.13.0",
    "typescript": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
