{
  "name": "life-focus",
  "private": true,
  "type": "module",
  "engines": { "node": ">=24" },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=apps/web\" \"npm run dev --workspace=apps/worker\"",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint . && depcruise --config .dependency-cruiser.cjs packages apps",
    "typecheck": "tsc --build tsconfig.build.json --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/eslint-parser": "^8.0.1",
    "@babel/preset-react": "^8.0.1",
    "@babel/preset-typescript": "^8.0.1",
    "@eslint/js": "^9.0.0",
    "@types/node": "^24.0.0",
    "concurrently": "^9.0.0",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^9.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "shadcn": "^4.13.0",
    "typescript": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
