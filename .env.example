# Life Focus Intelligence — Environment Variables
# Copy this file to .env and fill in values before running docker compose up

# === Database ===
# Standard Postgres connection string (no Supabase-specific features — AD-9)
# Only governs host-mode dev (running apps directly on your machine): containers use the
# compose-internal URL (postgres:5432) by design and ignore this value.
# Dev default when using docker compose:
DATABASE_URL=postgresql://lifefocus:lifefocus@localhost:5432/lifefocus

# Host-side port docker compose publishes Postgres on, bound to 127.0.0.1 (container always listens on 5432).
# Pairing hazard: if you override this, update DATABASE_URL's port to match for host-mode dev.
POSTGRES_HOST_PORT=5432

# === Application ===
PORT=3000
# Host-side port docker compose publishes the web app on (container always listens on 3000)
WEB_HOST_PORT=3000

# === Authentication (Better Auth — AD-6, single user) ===
# Secret used to sign sessions/tokens. MUST be at least 32 characters.
# Generate one with, e.g.: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-plus-secret
# Base URL Better Auth builds callback/cookie origins from.
BETTER_AUTH_URL=http://localhost:3000

# === Logging ===
# One of: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# === Runtime ===
NODE_ENV=development
